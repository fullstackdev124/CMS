{
  "name": "ecms-backend",
  "version": "1.0.1",
  "description": "eCMS Backend Application",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": "12 || 14 || 16 || 17"
  },
  "scripts": {
    "build": "lb-tsc",
    "build:watch": "lb-tsc --watch",
    "lint": "npm run eslint && npm run prettier:check",
    "lint:fix": "npm run eslint:fix && npm run prettier:fix",
    "prettier:cli": "lb-prettier \"**/*.ts\" \"**/*.js\"",
    "prettier:check": "npm run prettier:cli -- -l",
    "prettier:fix": "npm run prettier:cli -- --write",
    "eslint": "lb-eslint --report-unused-disable-directives .",
    "eslint:fix": "npm run eslint -- --fix",
    "pretest": "npm run rebuild",
    "test": "lb-mocha --allow-console-logs \"dist/__tests__\"",
    "posttest": "npm run lint",
    "test:dev": "lb-mocha --allow-console-logs dist/__tests__/**/*.js && npm run posttest",
    "docker:build": "docker build -t dash-ws-srv .",
    "docker:run": "docker run -p 3000:3000 -d dash-ws-srv",
    "premigrate": "NODE_ENV=dev node migration.js init",
    "migrate": "NODE_ENV=dev node migration.js migrate",
    "preopenapi-spec": "npm run build",
    "openapi-spec": "node ./dist/openapi-spec",
    "prestart": "npm run rebuild",
    "start": "node -r source-map-support/register .",
    "devel": "NODE_ENV=dev PORT=3002 node -r source-map-support/register .",
    "debug": "npm run rebuild && NODE_ENV=dev PORT=3002 ERROR=*,-express:router:route*,-strong-globalize*,-strong-remoting:rest-adapter,-express:router:layer,-loopback:datasource,-loopback:explorer:routeHelpers,-loopback:include,-loopback:context:binding node --inspect --trace-warnings -r source-map-support/register .",
    "debug2": "npm run rebuild && NODE_ENV=dev PORT=3003 node --inspect -r source-map-support/register .",
    "clean": "lb-clean dist *.tsbuildinfo .eslintcache",
    "rebuild": "npm run clean && npm run build",
    "pm2start": "npm run rebuild && NODE_ENV=prod pm2 start ecosystem.config.js --env prod",
    "pm2stop": "NODE_ENV=prod pm2 stop ecosystem.config.js --env prod",
    "pm2start-devel": "npm run rebuild && pm2 start ecosystem.config.js --env dev",
    "pm2stop-devel": "pm2 stop ecosystem.config.js --env dev"
  },
  "repository": {
    "type": "git",
    "url": "https://git.techfusion.it/call-metrics/ecms-backend"
  },
  "author": "danilo.santoro <danilo.santoro@techfusion.it>",
  "license": "",
  "files": [
    "README.md",
    "dist",
    "src",
    "!*/__tests__"
  ],
  "dependencies": {
    "@babel/polyfill": "^7.10.4",
    "@loopback/boot": "^6.1.0",
    "@loopback/booter-lb3app": "^5.1.0",
    "@loopback/core": "^5.1.0",
    "@loopback/logging": "^0.11.0",
    "@loopback/repository": "^6.1.0",
    "@loopback/rest": "^13.1.0",
    "@loopback/rest-explorer": "^6.1.0",
    "@loopback/service-proxy": "^6.1.0",
    "axios": "^1.4.0",
    "cluster": "^0.7.7",
    "compression": "^1.7.4",
    "exceljs": "^4.3.0",
    "handlebars": "^4.7.7",
    "helmet": "^7.0.0",
    "loopback-boot": "^3.3.1",
    "loopback-connector-mysql": "^6.2.0",
    "loopback-connector-rest": "^4.0.3",
    "loopback-context": "^3.5.2",
    "md5-file": "^5.0.0",
    "moment": "^2.29.4",
    "multer": "^1.4.5-lts.1",
    "mysql": "^2.18.1",
    "node-cache": "^5.1.2",
    "npm": "^9.7.2",
    "pm2": "^5.3.0",
    "redis": "^4.6.7",
    "stripe": "^12.11.0",
    "strong-error-handler": "^4.0.6",
    "sync-mysql": "^3.0.1",
    "telnyx": "^1.23.0",
    "tslib": "^2.6.0"
  },
  "devDependencies": {
    "@loopback/build": "^10.1.0",
    "@loopback/eslint-config": "^14.0.1",
    "@loopback/testlab": "^6.1.0",
    "@types/node": "^20.3.2",
    "eslint": "^8.43.0",
    "source-map-support": "^0.5.21",
    "typescript": "~5.1.6"
  }
}
